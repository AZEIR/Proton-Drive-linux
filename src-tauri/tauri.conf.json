{
  "productName": "Proton Drive",
  "version": "0.1.0",
  "identifier": "com.protondrive.sync",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "Proton Drive",
        "width": 680,
        "height": 520,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "label": "main",
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "resources": [
      "../sdk/js/cli/release/proton-fuse",
      "../sdk/js/cli/release/proton-sync"
    ]
  }
}
